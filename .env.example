# Copie para .env e preencha os valores. Nunca commite o .env real.

# Banco de dados (MySQL)
DATABASE_URL=

# Segredo usado para assinar cookies de sessão/acesso (qualquer string longa e aleatória)
JWT_SECRET=

# --- Gate de acesso por senha (independente do OAuth) ---
# Defina uma senha para proteger o acesso ao FlowMeasure.
# Se deixar em branco, o app fica acessível sem senha (mesmo comportamento de hoje).
ACCESS_PASSWORD=

# --- OAuth Manus (opcional, para login "de verdade" com usuários) ---
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# --- Storage (opcional, usado por geração de imagem) ---
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
